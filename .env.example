# ============================================
# منصة ذاكر - متغيرات البيئة المطلوبة
# انسخ هذا الملف إلى .env.local وعدّل القيم
# ============================================

# === قاعدة البيانات (Supabase) ===
# من: Supabase Dashboard > Project Settings > Database > Connection string
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# === NextAuth ===
# اصنع secret قوي: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-key-min-32-chars"
NEXTAUTH_URL="https://your-domain.vercel.app"
# في التطوير المحلي: NEXTAUTH_URL="http://localhost:3000"

# === Supabase ===
# من: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# === البريد الإلكتروني (اختياري - للـ email verification) ===
EMAIL_SERVER_HOST="smtp.gmail.com"
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER="your-email@gmail.com"
EMAIL_SERVER_PASSWORD="your-app-password"
EMAIL_FROM="ذاكر التعليمية <noreply@zakir.edu>"

# === عام ===
NEXT_PUBLIC_APP_URL="https://your-domain.vercel.app"
NEXT_PUBLIC_APP_NAME="ذاكر"
NODE_ENV="production"
